<jasperReport name="clientes_por_loja" language="java" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="06827ea2-a2ca-4799-b379-5ff002e28b0c">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="MySQL - Carteira Clientes"/>
	<query language="SQL"><![CDATA[
        
            SELECT
                l.nome AS loja_nome,
                c.nome AS cliente_nome,
                c.cpf AS cliente_cpf,
                c.telefone AS cliente_telefone,
                u.nome AS vendedor_nome,
                DATE_FORMAT(c.data_cadastro, '%d/%m/%Y') AS data_cadastro_formatada
            FROM cliente c
            INNER JOIN loja l ON l.id = c.loja_id
            INNER JOIN usuario u ON u.id = c.vendedor_id
            ORDER BY l.nome, c.nome
        
    ]]></query>
	<field name="loja_nome" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.label" value="loja_nome"/>
	</field>
