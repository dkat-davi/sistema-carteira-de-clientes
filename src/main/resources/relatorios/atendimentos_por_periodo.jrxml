<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 7.0.6-5d2a603fdc6b3db8f842a83383e594f41891534d  -->
<jasperReport name="atendimentos_por_periodo" language="java" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="e820fcaa-4e0c-4279-b6cc-55ea476c4c38">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="MySQL - Carteira Clientes"/>
	<parameter name="DATA_INICIO" class="java.sql.Timestamp"/>
	<parameter name="DATA_FIM" class="java.sql.Timestamp"/>
	<query language="SQL"><![CDATA[
        
            SELECT
                DATE_FORMAT(a.data_atendimento, '%d/%m/%Y %H:%i') AS data_atendimento_formatada,
                c.nome AS cliente_nome,
                u.nome AS usuario_nome,
                l.nome AS loja_nome,
                a.descricao AS descricao
            FROM atendimento a
            INNER JOIN cliente c ON c.id = a.cliente_id
            INNER JOIN usuario u ON u.id = a.usuario_id
            INNER JOIN loja l ON l.id = c.loja_id
            WHERE a.data_atendimento BETWEEN $P{DATA_INICIO} AND $P{DATA_FIM}
            ORDER BY a.data_atendimento DESC
        
    ]]></query>
	<field name="data_atendimento_formatada" class="java.lang.String"/>
	<field name="cliente_nome" class="java.lang.String"/>
	<field name="usuario_nome" class="java.lang.String"/>
	<field name="loja_nome" class="java.lang.String"/>
	<field name="descricao" class="java.lang.String"/>
	<title height="80" splitType="Stretch">
		<element kind="staticText" uuid="f99fc6a3-85c8-44b4-92f5-127a9155959a" x="0" y="5" width="802" height="30" fontSize="20.0" bold="true" hTextAlign="Center" vTextAlign="Middle">
			<text><![CDATA[Relatório de Atendimentos por Período]]></text>
		</element>
		<element kind="textField" uuid="38026b62-b698-420d-82d2-f1f69505f49d" x="0" y="42" width="802" height="18" fontSize="10.0" hTextAlign="Center" vTextAlign="Middle">
			<expression><![CDATA[
                "Período: "
                + new java.text.SimpleDateFormat("dd/MM/yyyy").format($P{DATA_INICIO})
                + " até "
                + new java.text.SimpleDateFormat("dd/MM/yyyy").format($P{DATA_FIM})
            ]]></expression>
		</element>
	</title>
	<pageHeader height="20" splitType="Stretch">
		<element kind="textField" uuid="8a3c2bd5-1eb9-4c9c-a5aa-7f13f3a5d08d" x="600" y="0" width="202" height="16" fontSize="9.0" hTextAlign="Right">
			<expression><![CDATA["Emitido em: " + new java.text.SimpleDateFormat("dd/MM/yyyy HH:mm").format(new java.util.Date())]]></expression>
		</element>
