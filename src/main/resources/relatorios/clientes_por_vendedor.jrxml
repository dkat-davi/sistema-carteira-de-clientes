<jasperReport name="clientes_por_vendedor" language="java" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="28ce2a84-3a01-4b13-bc52-05e1c54f4a01">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="MySQL - Carteira Clientes"/>
	<query language="SQL"><![CDATA[
        
            SELECT
                u.nome AS vendedor_nome,
                l.nome AS loja_nome,
                c.nome AS cliente_nome,
                c.cpf AS cliente_cpf,
                c.telefone AS cliente_telefone,
                DATE_FORMAT(c.data_cadastro, '%d/%m/%Y') AS data_cadastro_formatada
            FROM cliente c
            INNER JOIN usuario u ON u.id = c.vendedor_id
            INNER JOIN loja l ON l.id = c.loja_id
            ORDER BY u.nome, c.nome
        
    ]]></query>
	<field name="vendedor_nome" class="java.lang.String"/>
	<field name="loja_nome" class="java.lang.String"/>
	<field name="cliente_nome" class="java.lang.String"/>
	<field name="cliente_cpf" class="java.lang.String"/>
	<field name="cliente_telefone" class="java.lang.String"/>
	<field name="data_cadastro_formatada" class="java.lang.String"/>
