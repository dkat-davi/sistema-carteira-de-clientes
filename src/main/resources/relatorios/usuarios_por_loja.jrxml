<jasperReport name="usuarios_por_loja" language="java" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="f9f17994-c908-4625-8e44-d89cc06b4cc0">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="MySQL - Carteira Clientes"/>
	<query language="SQL"><![CDATA[
        
            SELECT
                l.nome AS loja_nome,
                u.nome AS usuario_nome,
                u.login AS usuario_login,
                u.role AS perfil,
                ul.cargo AS cargo
            FROM usuario_loja ul
            INNER JOIN usuario u ON u.id = ul.usuario_id
            INNER JOIN loja l ON l.id = ul.loja_id
            WHERE u.ativo = TRUE
            AND l.ativo = TRUE
            ORDER BY l.nome, ul.cargo, u.nome
        
    ]]></query>
	<field name="loja_nome" class="java.lang.String"/>
	<field name="usuario_nome" class="java.lang.String"/>
	<field name="usuario_login" class="java.lang.String"/>
	<field name="perfil" class="java.lang.String"/>
	<field name="cargo" class="java.lang.String"/>
